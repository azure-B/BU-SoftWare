PORT=5000
NODE_ENV=development
APP_NAME=express-app
CORS_ORIGIN=http://localhost:3000
# 운영: https://bustudent.netlify.app (Render URL이 아님!)
# 복수: https://bustudent.netlify.app,http://localhost:3000

# Supabase (Project Settings → API)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# 서버 전용 — Dashboard에서 복사, 절대 프론트/커밋 금지
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# (선택) Supabase Postgres 직접 연결 — pg 풀용
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# PGSSL=true

# JWT (로그인 토큰 — 운영 환경에서는 반드시 변경)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Kakao Local / Maps API (서버 시드·장소 검색)
KAKAO_REST_API_KEY=your-kakao-rest-api-key

# Resend (Render 등 클라우드 — SMTP 대신 권장)
# https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxx
# 도메인 미인증 시 테스트: 백석 학생 허브 <onboarding@resend.dev> (Resend 가입 이메일로만 발송 가능)
# 도메인 인증 후: 백석 학생 허브 <noreply@your-domain.com>
RESEND_FROM=백석 학생 허브 <onboarding@resend.dev>

# Nodemailer (로컬 SMTP — Render에서는 Resend 권장)
# ── 네이버 (2025.11~ 일반 비밀번호 SMTP 불가) ──
# 1) mail.naver.com → 환경설정 → POP3/IMAP → SMTP「사용함」
# 2) nid.naver.com → 보안설정 → 2단계 인증 ON
# 3) 보안설정 → 애플리케이션 비밀번호 → 새로 생성
# 4) SMTP_PASS = 애플리케이션 비밀번호 (로그인 비밀번호 X)
SMTP_HOST=smtp.naver.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-id@naver.com
SMTP_PASS=your-application-password
SMTP_FROM=백석 학생 허브
