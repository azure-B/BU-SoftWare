PORT=5000
NODE_ENV=development
APP_NAME=express-app
CORS_ORIGIN=http://localhost:3000
# 운영: https://bustudent.netlify.app (Render URL이 아님!)
# 복수: https://bustudent.netlify.app,http://localhost:3000

# Supabase (Project Settings → API)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# 서버 전용 — Dashboard에서 복사, 절대 프론트/커밋 금지
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# (선택) Supabase Postgres 직접 연결 — pg 풀용
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# PGSSL=true

# JWT (로그인 토큰 — 운영 환경에서는 반드시 변경)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Kakao Local / Maps API (서버 시드·장소 검색)
KAKAO_REST_API_KEY=your-kakao-rest-api-key

# Nodemailer — Gmail SMTP (회원가입 이메일 인증)
# 1) myaccount.google.com → 보안 → 2단계 인증 ON
# 2) myaccount.google.com/apppasswords → 앱 비밀번호 생성 (16자리)
# 3) SMTP_USER = Gmail 전체 주소, SMTP_PASS = 앱 비밀번호 (공백 제거)
# 587 + STARTTLS 권장 (Render 포함). 465 SSL도 가능: PORT=465, SMTP_SECURE=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-account@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=백석 학생 허브
