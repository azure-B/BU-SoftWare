PORT=5000
NODE_ENV=development
APP_NAME=express-app
CORS_ORIGIN=http://localhost:3000
# 운영: https://bustudent.netlify.app (Render URL이 아님!)
# 복수: https://bustudent.netlify.app,http://localhost:3000

# Supabase (Project Settings → API)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# 서버 전용 — Dashboard에서 복사, 절대 프론트/커밋 금지
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# (선택) Supabase Postgres 직접 연결 — pg 풀용
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# PGSSL=true

# JWT (로그인 토큰 — 운영 환경에서는 반드시 변경)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Kakao Local / Maps API (서버 시드·장소 검색)
KAKAO_REST_API_KEY=your-kakao-rest-api-key

# Gmail API — 회원가입 이메일 인증 (Render Free 권장: SMTP 포트 차단 우회)
# 1) Google Cloud Console에서 Gmail API 사용 설정
# 2) OAuth 동의 화면 구성
# 3) OAuth Client ID(웹 애플리케이션) 생성
# 4) OAuth Playground 등으로 refresh token 발급
GMAIL_CLIENT_ID=your-google-oauth-client-id
GMAIL_CLIENT_SECRET=your-google-oauth-client-secret
GMAIL_REFRESH_TOKEN=your-google-refresh-token
GMAIL_USER=your-account@gmail.com

# Nodemailer — SMTP fallback
# Render Free는 Gmail/Naver 표준 SMTP 포트 25/465/587 아웃바운드를 차단함.
# Render Free에서 SMTP를 계속 쓰려면 SendGrid/Mailgun/SMTP2GO 등 2525 포트 지원 릴레이 사용.
# 예: SendGrid SMTP
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=2525
#   SMTP_USER=apikey
#   SMTP_PASS=sendgrid-api-key
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_USER=apikey
SMTP_PASS=your-smtp-relay-password-or-api-key
SMTP_FROM="백석 학생 허브" <your-account@gmail.com>
